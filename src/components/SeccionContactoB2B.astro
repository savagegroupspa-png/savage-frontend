---
// src/components/SeccionContactoB2B.astro
---

<div id="contacto" class="contacto-wrapper">

    <!-- CABECERA CORPORATIVA -->
    <section class="cabecera-corporativa">
        <div class="contenido-corporativo">
            <div class="contenedor-icono">
                <img
                    src="https://res.cloudinary.com/dauuk5yar/image/upload/v1773679337/chile_nfoces.jpg"
                    alt="Mapa de Chile Savage"
                    class="icono-imagen img-chile"
                />
            </div>
            <div class="textos-corporativos">
                <h2>SAVAGE GROUP SpA</h2>
                <p class="tagline-corp">INNOVACIÓN EN CONSUMO MASIVO</p>
                <p class="proximamente">Próximamente Energy Range.</p>
                <div class="linea-dorada-corta"></div>
                <p class="manager-text">Regional Manager: <span class="resalte-dorado">SEBASTIÁN DURÁN</span></p>
            </div>
            <div class="contenedor-icono">
                <img
                    src="https://res.cloudinary.com/dauuk5yar/image/upload/v1773679339/trato_vmnp4b.jpg"
                    alt="Savage Group Trato"
                    class="icono-imagen img-trato"
                />
            </div>
        </div>
    </section>

    <!-- SECCIÓN FORMULARIOS -->
    <section class="seccion-formularios">

        <div class="headline-wrapper">
            <span class="badge-zonas">⚡ ZONAS EXCLUSIVAS DISPONIBLES</span>
            <h2 class="titulo-principal">SÉ EL PRIMERO<br>EN TU ZONA</h2>
            <p class="subtitulo-principal">Distribuidores y comercios al por mayor: asegura tu territorio antes que la competencia.</p>
        </div>

        <!-- SELECTOR DE TABS -->
        <div class="selector-tabs">

            <button class="tab-card activo" id="tab-b2b" data-tab="b2b">
                <div class="tab-tag">RECOMENDADO</div>
                <div class="tab-icono">🏪</div>
                <h3 class="tab-titulo">SOY DISTRIBUIDOR</h3>
                <p class="tab-desc">Botillerías, supermercados, mayoristas y comercio al por mayor.</p>
                <div class="tab-indicador"></div>
            </button>

            <button class="tab-card" id="tab-b2c" data-tab="b2c">
                <div class="tab-icono">🔥</div>
                <h3 class="tab-titulo">SOY FAN</h3>
                <p class="tab-desc">Quiero ser el primero en probar Savage cuando llegue al mercado.</p>
                <div class="tab-indicador"></div>
            </button>

        </div>

        <!-- FORMULARIOS -->
        <div class="formularios-wrapper">

            <!-- FORM B2B -->
            <div class="panel-formulario activo" id="panel-b2b">
                <div class="panel-header">
                    <span class="panel-tag">DISTRIBUIDORES · B2B</span>
                    <h3>QUIERO DISTRIBUIR SAVAGE</h3>
                    <p class="panel-desc">Completa el formulario y recibirás nuestro dossier comercial con precios mayoristas, condiciones y zonas disponibles.</p>
                </div>
                <form class="formulario" id="form-b2b">
                    <div class="fila-doble">
                        <input type="text" name="nombre" placeholder="NOMBRE / CARGO" required />
                        <input type="text" name="empresa" placeholder="RAZÓN SOCIAL" required />
                    </div>
                    <div class="fila-doble">
                        <input type="email" name="email" placeholder="EMAIL CORPORATIVO" required />
                        <input type="text" name="ciudad" placeholder="CIUDAD / REGIÓN" required />
                    </div>
                    <textarea name="mensaje" placeholder="CUÉNTANOS TU OPERACIÓN: ¿QUÉ TIPO DE NEGOCIO TIENES? ¿CUÁNTOS PUNTOS DE VENTA?" rows="4" required></textarea>
                    <button type="submit" class="boton-primario">SOLICITAR DOSSIER COMERCIAL →</button>
                    <p id="msg-b2b" class="mensaje-status"></p>
                </form>
            </div>

            <!-- FORM B2C -->
            <div class="panel-formulario" id="panel-b2c">
                <div class="panel-header">
                    <span class="panel-tag b2c">CONSUMIDORES · B2C</span>
                    <h3>ÚNETE A LA MANADA</h3>
                    <p class="panel-desc">Ingresa tu email y te avisamos el día exacto del lanzamiento. Acceso anticipado garantizado.</p>
                </div>
                <form class="formulario" id="form-b2c">
                    <input type="text" name="nombre" placeholder="TU NOMBRE" required />
                    <input type="email" name="email" placeholder="TU EMAIL" required />
                    <button type="submit" class="boton-secundario">AVÍSAME AL LANZAR 🔥</button>
                    <p id="msg-b2c" class="mensaje-status"></p>
                </form>
            </div>

        </div>
    </section>

    <!-- FOOTER -->
    <footer class="footer-savage">
        <div class="redes-sociales">
            <a href="https://www.instagram.com/savagesdrinks/" target="_blank" rel="noopener noreferrer">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                </svg>
            </a>
        </div>
        <p class="email-contacto">sebastian@drinkssavage.com</p>
        <div class="linea-separadora"></div>
        <p class="copyright">© 2026 Savage Group SpA. Todos los derechos reservados.</p>
    </footer>

</div>

<script>
    const isLocal = window.location.hostname === "localhost";
    const API_URL = isLocal
        ? "http://localhost:3000/api"
        : "https://savage-backend-production.up.railway.app/api";

    // ── TABS ──
    const tabs = document.querySelectorAll('.tab-card');
    const panels = document.querySelectorAll('.panel-formulario');

    tabs.forEach(tab => {
        tab.addEventListener('click', () => {
            const target = (tab as HTMLElement).dataset.tab;

            tabs.forEach(t => t.classList.remove('activo'));
            panels.forEach(p => p.classList.remove('activo'));

            tab.classList.add('activo');
            document.getElementById(`panel-${target}`)?.classList.add('activo');
        });
    });

    // ── FORMULARIOS ──
    async function iniciarFormularios() {
        const manejarEnvio = async (idForm: string, idMsg: string, endpoint: string, mensajeExito: string) => {
            const form = document.getElementById(idForm) as HTMLFormElement | null;
            const statusMsg = document.getElementById(idMsg);
            if (!form || !statusMsg) return;

            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                statusMsg.textContent = "ENVIANDO...";
                statusMsg.style.color = "#facc15";

                const data = Object.fromEntries(new FormData(form));

                try {
                    const response = await fetch(`${API_URL}/${endpoint}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });

                    if (response.ok) {
                        statusMsg.textContent = mensajeExito;
                        statusMsg.style.color = "#facc15";
                        form.reset();
                        setTimeout(() => { statusMsg.textContent = ""; }, 6000);
                    } else {
                        const errorData = await response.json();
                        statusMsg.textContent = `❌ ERROR: ${errorData.error || 'SERVIDOR'}`;
                        statusMsg.style.color = "#f87171";
                    }
                } catch {
                    statusMsg.textContent = "❌ SIN CONEXIÓN CON EL BACKEND.";
                    statusMsg.style.color = "#f87171";
                }
            });
        };

        manejarEnvio('form-b2b', 'msg-b2b', 'distribuidores', "✅ DOSSIER SOLICITADO. REVISA TU MAIL.");
        manejarEnvio('form-b2c', 'msg-b2c', 'fans', "🔥 ¡YA ERES PARTE DE LA MANADA!");
    }

    document.addEventListener('DOMContentLoaded', iniciarFormularios);
</script>

<style>
    .contacto-wrapper { width: 100%; display: flex; flex-direction: column; }

    /* ── CABECERA CORPORATIVA ── */
    .cabecera-corporativa {
        background-color: #000000;
        padding: 80px 20px 40px;
        text-align: center;
        border-top: 1px solid rgba(255,255,255,0.05);
    }
    .contenido-corporativo {
        max-width: 1000px;
        margin: 0 auto;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 60px;
    }
    .icono-imagen {
        width: auto; object-fit: contain;
        filter: invert(1); opacity: 0.85;
        transition: transform 0.3s ease, opacity 0.3s ease;
    }
    .icono-imagen:hover { opacity: 1; transform: scale(1.05); }
    .img-chile { height: 160px; }
    .img-trato { height: 110px; }
    .textos-corporativos { display: flex; flex-direction: column; align-items: center; }
    .textos-corporativos h2 {
        font-family: 'Oswald', sans-serif; font-size: 3rem;
        color: #ffffff; margin: 0 0 5px 0; letter-spacing: 1px;
    }
    .tagline-corp {
        font-family: 'Inter', sans-serif; font-size: 1.1rem;
        color: #a3a3a3; letter-spacing: 3px; margin: 0 0 5px 0;
        text-transform: uppercase; font-weight: 600;
    }
    .proximamente {
        font-family: 'Inter', sans-serif; font-size: 1rem;
        color: #666666; margin: 0 0 20px 0; font-style: italic;
    }
    .linea-dorada-corta {
        width: 40px; height: 2px;
        background-color: #facc15; margin: 0 auto 20px;
    }
    .manager-text { font-family: 'Inter', sans-serif; font-size: 1.2rem; color: #cccccc; margin: 0; }
    .resalte-dorado { color: #facc15; font-weight: 700; }

    /* ── SECCIÓN FORMULARIOS ── */
    .seccion-formularios {
        background-color: #0a0a0a;
        padding: 100px 20px 100px;
        border-bottom: 1px solid #1a1a1a;
    }

    /* HEADLINE */
    .headline-wrapper {
        max-width: 1200px;
        margin: 0 auto 70px;
        text-align: center;
    }
    .badge-zonas {
        display: inline-block;
        background-color: rgba(250, 204, 21, 0.12);
        border: 1px solid rgba(250, 204, 21, 0.35);
        color: #facc15;
        font-family: 'Inter', sans-serif;
        font-size: 0.7rem; font-weight: 700;
        letter-spacing: 3px; text-transform: uppercase;
        padding: 6px 18px; border-radius: 100px; margin-bottom: 28px;
    }
    .titulo-principal {
        font-family: 'Oswald', sans-serif;
        font-size: clamp(3.5rem, 7vw, 6rem);
        font-weight: 700; color: #ffffff;
        letter-spacing: 2px; line-height: 1.0; margin: 0 0 24px 0;
    }
    .subtitulo-principal {
        font-family: 'Inter', sans-serif; font-size: 1rem;
        color: #666666; letter-spacing: 0.5px;
        max-width: 500px; margin: 0 auto; line-height: 1.7;
    }

    /* ── SELECTOR DE TABS ── */
    .selector-tabs {
        max-width: 1200px;
        margin: 0 auto 0;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .tab-card {
        position: relative;
        background-color: #111111;
        border: 1px solid #222222;
        border-radius: 12px 12px 0 0;
        padding: 36px 40px;
        cursor: pointer;
        text-align: left;
        transition: background-color 0.25s ease, border-color 0.25s ease;
        overflow: hidden;
    }
    .tab-card:hover {
        background-color: #161616;
        border-color: #333333;
    }
    .tab-card.activo {
        background-color: #141414;
        border-color: #facc15;
        border-bottom-color: #141414;
    }

    .tab-tag {
        display: inline-block;
        background-color: #facc15;
        color: #000000;
        font-family: 'Inter', sans-serif;
        font-size: 0.6rem; font-weight: 800;
        letter-spacing: 3px; text-transform: uppercase;
        padding: 3px 10px; border-radius: 2px;
        margin-bottom: 16px;
        visibility: hidden;
    }
    .tab-card:first-child .tab-tag { visibility: visible; }

    .tab-icono {
        font-size: 2rem;
        margin-bottom: 12px;
        display: block;
    }
    .tab-titulo {
        font-family: 'Oswald', sans-serif;
        font-size: 1.6rem; font-weight: 700;
        color: #ffffff; margin: 0 0 10px 0;
        letter-spacing: 1px;
        transition: color 0.25s ease;
    }
    .tab-card:not(.activo) .tab-titulo { color: #666666; }

    .tab-desc {
        font-family: 'Inter', sans-serif;
        font-size: 0.85rem; color: #555555;
        line-height: 1.6; margin: 0;
        transition: color 0.25s ease;
    }
    .tab-card.activo .tab-desc { color: #888888; }

    .tab-indicador {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 3px;
        background-color: transparent;
        transition: background-color 0.25s ease;
    }
    .tab-card.activo .tab-indicador { background-color: #facc15; }

    /* ── PANEL DE FORMULARIO ── */
    .formularios-wrapper {
        max-width: 1200px;
        margin: 0 auto;
    }

    .panel-formulario {
        display: none;
        background-color: #141414;
        border: 1px solid #facc15;
        border-top: none;
        border-radius: 0 0 12px 12px;
        padding: 56px 56px 56px;
        animation: fadePanel 0.3s ease;
    }
    .panel-formulario.activo { display: block; }

    @keyframes fadePanel {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .panel-header { margin-bottom: 40px; }
    .panel-tag {
        display: inline-block;
        background-color: #facc15;
        color: #000000;
        font-family: 'Inter', sans-serif;
        font-size: 0.65rem; font-weight: 800;
        letter-spacing: 3px; text-transform: uppercase;
        padding: 4px 12px; border-radius: 2px; margin-bottom: 18px;
    }
    .panel-tag.b2c {
        background-color: transparent;
        border: 1px solid #333333;
        color: #666666;
    }
    .panel-header h3 {
        font-family: 'Oswald', sans-serif;
        font-size: clamp(1.8rem, 3vw, 2.6rem);
        color: #ffffff; margin: 0 0 14px 0; letter-spacing: 1px;
    }
    .panel-desc {
        font-family: 'Inter', sans-serif;
        font-size: 0.95rem; color: #555555; line-height: 1.7; margin: 0;
        max-width: 600px;
    }

    /* INPUTS */
    .formulario { display: flex; flex-direction: column; gap: 16px; }
    .fila-doble { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

    .formulario input,
    .formulario textarea {
        background-color: #0d0d0d;
        border: 1px solid #252525;
        border-radius: 6px;
        padding: 16px 18px;
        color: #ffffff;
        font-family: 'Inter', sans-serif;
        font-size: 0.85rem; letter-spacing: 0.5px;
        transition: border-color 0.2s ease, background-color 0.2s ease;
        width: 100%; box-sizing: border-box;
    }
    .formulario input:focus,
    .formulario textarea:focus {
        outline: none;
        border-color: #facc15;
        background-color: #111111;
    }
    .formulario input::placeholder,
    .formulario textarea::placeholder { color: #3a3a3a; font-size: 0.8rem; letter-spacing: 1px; }

    .boton-primario {
        background-color: #facc15; color: #000000;
        font-family: 'Oswald', sans-serif;
        font-size: 1.15rem; font-weight: 700;
        border: none; border-radius: 6px;
        padding: 20px; cursor: pointer;
        text-transform: uppercase; letter-spacing: 2px;
        transition: background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
        margin-top: 8px; width: 100%;
    }
    .boton-primario:hover {
        background-color: #eab308;
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(250, 204, 21, 0.2);
    }

    .boton-secundario {
        background-color: transparent; color: #888888;
        font-family: 'Oswald', sans-serif;
        font-size: 1rem; font-weight: 700;
        border: 1px solid #2a2a2a; border-radius: 6px;
        padding: 18px; cursor: pointer;
        text-transform: uppercase; letter-spacing: 2px;
        transition: border-color 0.2s ease, color 0.2s ease;
        margin-top: 8px; width: 100%;
    }
    .boton-secundario:hover { border-color: #facc15; color: #facc15; }

    /* STATUS */
    .mensaje-status {
        font-family: 'Inter', sans-serif;
        font-size: 0.8rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 1px;
        min-height: 1.2em; margin-top: 4px;
    }

    /* ── FOOTER ── */
    .footer-savage { background-color: #050505; padding: 50px 20px 30px; text-align: center; }
    .redes-sociales { display: flex; justify-content: center; gap: 20px; margin-bottom: 15px; }
    .redes-sociales a { color: #ffffff; transition: color 0.3s ease; }
    .redes-sociales a:hover { color: #facc15; }
    .email-contacto { font-family: 'Inter', sans-serif; font-size: 1.1rem; color: #ffffff; margin-bottom: 30px; }
    .linea-separadora { width: 100%; max-width: 800px; height: 1px; background-color: #222222; margin: 0 auto 20px; }
    .copyright { font-family: 'Inter', sans-serif; font-size: 0.75rem; color: #666666; }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
        .panel-formulario { padding: 40px 28px; }
        .fila-doble { grid-template-columns: 1fr; }
    }
    @media (max-width: 768px) {
        .contenido-corporativo { flex-direction: column; gap: 40px; }
        .img-chile { height: 120px; }
        .img-trato { height: 90px; }
        .selector-tabs { grid-template-columns: 1fr; }
        .tab-card { border-radius: 12px; }
        .tab-card.activo { border-bottom-color: #facc15; }
        .panel-formulario { border-radius: 12px; border-top: 1px solid #facc15; margin-top: 8px; }
    }
</style>
