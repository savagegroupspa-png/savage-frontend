---
// src/components/SeccionContactoB2B.astro
---

<div id="contacto" class="contacto-wrapper">
    <section class="cabecera-corporativa">
        <div class="contenido-corporativo">
            <div class="contenedor-icono">
                <img 
                    src="https://res.cloudinary.com/dauuk5yar/image/upload/v1773679337/chile_nfoces.jpg" 
                    alt="Mapa de Chile Savage" 
                    class="icono-imagen img-chile" 
                />
            </div>

            <div class="textos-corporativos">
                <h2>SAVAGE GROUP SpA</h2>
                <p class="tagline-corp">INNOVACIÓN EN CONSUMO MASIVO</p>
                <p class="proximamente">Próximamente Energy Range.</p>
                <div class="linea-dorada-corta"></div>
                <p class="manager-text">Regional Manager: <span class="resalte-dorado">SEBASTIÁN DURÁN</span></p>
            </div>

            <div class="contenedor-icono">
                <img 
                    src="https://res.cloudinary.com/dauuk5yar/image/upload/v1773679339/trato_vmnp4b.jpg" 
                    alt="Savage Group Trato" 
                    class="icono-imagen img-trato" 
                />
            </div>
        </div>
    </section>

    <section class="seccion-formularios">
    <h2 class="titulo-manada">FORMA PARTE DE LA MANADA</h2>
    
    <div class="grid-formularios">
        <div class="caja-formulario">
            <h3>PARA DISTRIBUIDORES (B2B)</h3>
            <form class="formulario" id="form-b2b">
                <input type="text" name="nombre" placeholder="NOMBRE COMPLETO / CARGO" required />
                <input type="text" name="empresa" placeholder="RAZÓN SOCIAL (EMPRESA)" required />
                <input type="email" name="email" placeholder="EMAIL CORPORATIVO" required />
                <input type="text" name="ciudad" placeholder="CIUDAD / PAÍS" required />
                <textarea name="mensaje" placeholder="MENSAJE" rows="3" required></textarea>
                <button type="submit" class="boton-dorado">SOLICITAR DOSSIER COMERCIAL</button>
                <p id="msg-b2b" class="mensaje-status"></p>
            </form>
        </div>

        <div class="caja-formulario">
            <h3>PARA FANS Y LANZAMIENTO (B2C)</h3>
            <form class="formulario" id="form-b2c">
                <input type="text" name="nombre" placeholder="TU NOMBRE" required />
                <input type="email" name="email" placeholder="TU EMAIL" required />
                <button type="submit" class="boton-dorado">AVÍSAME AL LANZAR</button>
                <p id="msg-b2c" class="mensaje-status"></p>
            </form>
        </div>
    </div>
</section>

<footer class="footer-savage">
    <div class="redes-sociales">
        <a href="https://www.instagram.com/savagesdrinks?igsh=MXRpYzdpMmtteTB3" target="_blank" rel="noopener noreferrer">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
        </a>
        </div>
    <p class="email-contacto">sebastian@drinkssavage.com</p>
    <div class="linea-separadora"></div>
    <p class="copyright">© 2026 Savage Group SpA. Todos los derechos reservados.</p>
</footer>
</div>

<style>
    /* ESTILOS GENERALES */
    .contacto-wrapper { width: 100%; display: flex; flex-direction: column; background-color: #000; }
    
    /* CABECERA */
    .cabecera-corporativa { background-color: #000000; padding: 80px 20px 40px; text-align: center; border-top: 1px solid rgba(255, 255, 255, 0.05); }
    .contenido-corporativo { max-width: 1000px; margin: 0 auto; display: flex; justify-content: center; align-items: center; gap: 60px; }
    .icono-imagen { height: auto; object-fit: contain; filter: invert(1); opacity: 0.85; transition: transform 0.3s ease; }
    .img-chile { height: 160px; }
    .img-trato { height: 110px; }
    .textos-corporativos h2 { font-family: 'Oswald', sans-serif; font-size: 3rem; color: #fff; margin: 0; }
    .tagline-corp { color: #a3a3a3; letter-spacing: 3px; text-transform: uppercase; font-weight: 600; }
    .linea-dorada-corta { width: 40px; height: 2px; background-color: #facc15; margin: 20px auto; }
    .resalte-dorado { color: #facc15; }

    /* FORMULARIOS */
    .seccion-formularios { background-color: #0a0a0a; padding: 80px 20px; text-align: center; }
    .titulo-manada { font-family: 'Oswald', sans-serif; font-size: 2.5rem; color: #fff; margin-bottom: 50px; }
    .grid-formularios { max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; text-align: left; }
    .caja-formulario h3 { font-family: 'Oswald', sans-serif; color: #fff; margin-bottom: 20px; }
    .formulario { display: flex; flex-direction: column; gap: 15px; }
    .formulario input, .formulario textarea { background-color: transparent; border: 1px solid #333; padding: 12px; color: #fff; }
    .formulario input:focus { border-color: #facc15; outline: none; }
    .boton-dorado { background-color: #facc15; color: #000; font-family: 'Oswald', sans-serif; font-weight: 700; padding: 15px; cursor: pointer; border: none; }
    .boton-dorado:hover { background-color: #eab308; }

    /* MENSAJES DE STATUS */
    .mensaje-status {
        margin-top: 1rem;
        font-size: 0.85rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        min-height: 1.2em;
    }

    /* FOOTER */
    .footer-savage { background-color: #050505; padding: 50px 20px; text-align: center; }
    .redes-sociales { display: flex; justify-content: center; gap: 20px; margin-bottom: 20px; }
    .redes-sociales a { color: #fff; }
    .linea-separadora { width: 100%; max-width: 800px; height: 1px; background-color: #222; margin: 20px auto; }

    @media (max-width: 768px) {
        .contenido-corporativo { flex-direction: column; }
        .grid-formularios { grid-template-columns: 1fr; }
    }
</style>

<script>
    // Lógica inteligente: Si existe la variable en Render, la usa. 
    // Si estás en tu PC (localhost), usa la ruta local.
    const isLocal = window.location.hostname === "localhost";
    const API_URL = isLocal 
        ? "http://localhost:3000/api" 
        : "https://savage-backend-production.up.railway.app/api";

    async function iniciarFormularios() {
        const manejarEnvio = async (idForm: string, idMsg: string, endpoint: string, mensajeExito: string) => {
            const form = document.getElementById(idForm) as HTMLFormElement | null;
            const statusMsg = document.getElementById(idMsg);
            
            if (!form || !statusMsg) return;

            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                
                statusMsg.textContent = "ENVIANDO A LA MANADA...";
                statusMsg.style.color = "#facc15";

                const formData = new FormData(form);
                const data = Object.fromEntries(formData);

                try {
                    // Usamos la API_URL dinámica
                    const response = await fetch(`${API_URL}/${endpoint}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });

                    if (response.ok) {
                        statusMsg.textContent = mensajeExito;
                        statusMsg.style.color = "#facc15"; 
                        form.reset();
                        setTimeout(() => { statusMsg.textContent = ""; }, 6000);
                    } else {
                        const errorData = await response.json();
                        statusMsg.textContent = `❌ ERROR: ${errorData.error || 'SERVIDOR'}`;
                        statusMsg.style.color = "#f87171";
                    }
                } catch (error) {
                    console.error("Error en el envío:", error);
                    statusMsg.textContent = "❌ SIN CONEXIÓN CON EL BACKEND.";
                    statusMsg.style.color = "#f87171";
                }
            });
        };

        // Activamos los dos formularios
        manejarEnvio('form-b2b', 'msg-b2b', 'distribuidores', "✅ DOSSIER SOLICITADO. REVISA TU MAIL.");
        manejarEnvio('form-b2c', 'msg-b2c', 'fans', "🔥 ¡YA ERES PARTE DE LA MANADA!");
    }

    // Ejecutar cuando el DOM esté listo
    document.addEventListener('DOMContentLoaded', iniciarFormularios);
    // Para compatibilidad con transiciones de Astro
    iniciarFormularios();
</script>

<style>
    .mensaje-status {
        margin-top: 1rem;
        font-size: 0.9rem;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 1px;
        min-height: 1.2em; /* Evita que el layout salte */
    }
</style>

<style>
    .contacto-wrapper { width: 100%; display: flex; flex-direction: column; }

    /* 1. NUEVA CABECERA CORPORATIVA OSCURA */
    .cabecera-corporativa {
        background-color: #000000;
        padding: 80px 20px 40px;
        text-align: center;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .contenido-corporativo {
        max-width: 1000px;
        margin: 0 auto;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 60px;
    }

    /* EL TRUCO MAGNÍFICO: Invierte los colores de tus fotos para que sean blancas sobre negro */
    .icono-imagen {
        width: auto;
        object-fit: contain;
        filter: invert(1); 
        opacity: 0.85;
        transition: transform 0.3s ease, opacity 0.3s ease;
    }
    .icono-imagen:hover {
        opacity: 1;
        transform: scale(1.05);
    }

    .img-chile { height: 160px; }
    .img-trato { height: 110px; }

    .textos-corporativos { display: flex; flex-direction: column; align-items: center; }

    .textos-corporativos h2 {
        font-family: 'Oswald', sans-serif;
        font-size: 3rem;
        color: #ffffff;
        margin: 0 0 5px 0;
        letter-spacing: 1px;
    }

    .tagline-corp {
        font-family: 'Inter', sans-serif;
        font-size: 1.1rem;
        color: #a3a3a3;
        letter-spacing: 3px;
        margin: 0 0 5px 0;
        text-transform: uppercase;
        font-weight: 600;
    }

    .proximamente {
        font-family: 'Inter', sans-serif;
        font-size: 1rem;
        color: #666666;
        margin: 0 0 20px 0;
        font-style: italic;
    }

    .linea-dorada-corta {
        width: 40px;
        height: 2px;
        background-color: #facc15;
        margin: 0 auto 20px;
    }

    .manager-text {
        font-family: 'Inter', sans-serif;
        font-size: 1.2rem;
        color: #cccccc;
        margin: 0;
    }

    .resalte-dorado { color: #facc15; font-weight: 700; }

    /* 2. FORMULARIOS */
    .seccion-formularios {
        background-color: #0a0a0a;
        padding: 80px 20px;
        text-align: center;
        border-bottom: 1px solid #222;
    }

    .titulo-manada { font-family: 'Oswald', sans-serif; font-size: 2.5rem; color: #ffffff; margin-bottom: 50px; letter-spacing: 1px; }

    .grid-formularios { max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; text-align: left; }

    .caja-formulario h3 { font-family: 'Oswald', sans-serif; font-size: 1.2rem; color: #ffffff; margin-bottom: 20px; letter-spacing: 1px; }

    .formulario { display: flex; flex-direction: column; gap: 15px; }
    .formulario input, .formulario textarea { background-color: transparent; border: 1px solid #333333; border-radius: 4px; padding: 12px 15px; color: #ffffff; font-family: 'Inter', sans-serif; font-size: 0.9rem; transition: border-color 0.3s ease; }
    .formulario input:focus, .formulario textarea:focus { outline: none; border-color: #facc15; }
    .formulario input::placeholder, .formulario textarea::placeholder { color: #666666; }

    .boton-dorado { background-color: #facc15; color: #000000; font-family: 'Oswald', sans-serif; font-size: 1.1rem; font-weight: 700; border: none; border-radius: 4px; padding: 15px; cursor: pointer; text-transform: uppercase; transition: background-color 0.3s ease, transform 0.2s ease; margin-top: 10px; }
    .boton-dorado:hover { background-color: #eab308; transform: translateY(-2px); }

    /* 3. FOOTER */
    .footer-savage { background-color: #050505; padding: 50px 20px 30px; text-align: center; position: relative; }
    .redes-sociales { display: flex; justify-content: center; gap: 20px; margin-bottom: 15px; }
    .redes-sociales a { color: #ffffff; transition: color 0.3s ease; }
    .redes-sociales a:hover { color: #facc15; }
    .email-contacto { font-family: 'Inter', sans-serif; font-size: 1.1rem; color: #ffffff; margin-bottom: 30px; }
    .linea-separadora { width: 100%; max-width: 800px; height: 1px; background-color: #222222; margin: 0 auto 20px; }
    .copyright { font-family: 'Inter', sans-serif; font-size: 0.75rem; color: #666666; }
    .estrella-decorativa { position: absolute; bottom: 20px; right: 40px; width: 50px; color: #333333; }

    /* RESPONSIVE */
    @media (max-width: 768px) {
        .contenido-corporativo { flex-direction: column; gap: 40px; }
        .grid-formularios { grid-template-columns: 1fr; gap: 50px; }
        .estrella-decorativa { display: none; }
        .img-chile { height: 120px; }
        .img-trato { height: 90px; }
    }
</style>
