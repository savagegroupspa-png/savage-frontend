---
// src/components/SeccionStats.astro
---

<section class="seccion-stats">
    <div class="stats-grid">

        <div class="stat-item" data-target="50" data-suffix="%">
            <span class="stat-numero"><span class="contador">0</span>%</span>
            <span class="stat-label">FRUTA REAL</span>
            <span class="stat-desc">Pulpa y semillas naturales en cada lata</span>
        </div>

        <div class="divisor"></div>

        <div class="stat-item" data-target="4" data-suffix="">
            <span class="stat-numero"><span class="contador">0</span></span>
            <span class="stat-label">SABORES</span>
            <span class="stat-desc">Passion, Pineapple, Mango & Exotic</span>
        </div>

        <div class="divisor"></div>

        <div class="stat-item" data-target="100" data-suffix="%">
            <span class="stat-numero"><span class="contador">0</span>%</span>
            <span class="stat-label">SAVAGE</span>
            <span class="stat-desc">Sin artificiales. Sin compromisos</span>
        </div>

        <div class="divisor"></div>

        <div class="stat-item" data-target="0" data-suffix="">
            <span class="stat-numero"><span class="contador">0</span></span>
            <span class="stat-label">ARTIFICIALES</span>
            <span class="stat-desc">Cero conservantes. Solo instinto puro</span>
        </div>

    </div>
</section>

<script>
    const animarContador = (el: HTMLElement, target: number, duracion: number) => {
        const inicio = performance.now();
        const update = (ahora: number) => {
            const progreso = Math.min((ahora - inicio) / duracion, 1);
            const eased = 1 - Math.pow(1 - progreso, 3);
            el.textContent = String(Math.floor(eased * target));
            if (progreso < 1) requestAnimationFrame(update);
        };
        requestAnimationFrame(update);
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const item = entry.target as HTMLElement;
                const target = parseInt(item.dataset.target || '0');
                const contador = item.querySelector('.contador') as HTMLElement;
                animarContador(contador, target, 1800);
                item.classList.add('visible');
                observer.unobserve(item);
            }
        });
    }, { threshold: 0.4 });

    document.querySelectorAll('.stat-item').forEach(el => observer.observe(el));
</script>

<style>
    .seccion-stats {
        width: 100%;
        background-color: #050505;
        border-top: 1px solid #111;
        border-bottom: 1px solid #111;
        padding: 70px 20px;
    }

    .stats-grid {
        max-width: 1100px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0;
    }

    .divisor {
        width: 1px;
        height: 60px;
        background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.12), transparent);
        flex-shrink: 0;
        margin: 0 20px;
    }

    .stat-item {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 0 20px;
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.7s ease, transform 0.7s ease;
    }

    .stat-item:nth-child(1) { transition-delay: 0s; }
    .stat-item:nth-child(3) { transition-delay: 0.1s; }
    .stat-item:nth-child(5) { transition-delay: 0.2s; }
    .stat-item:nth-child(7) { transition-delay: 0.3s; }

    .stat-item.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .stat-numero {
        font-family: 'Oswald', sans-serif;
        font-size: clamp(2.8rem, 5vw, 4.5rem);
        font-weight: 700;
        color: #facc15;
        line-height: 1;
        margin-bottom: 10px;
        letter-spacing: -1px;
    }

    .stat-label {
        font-family: 'Oswald', sans-serif;
        font-size: 0.85rem;
        font-weight: 700;
        color: #ffffff;
        letter-spacing: 3px;
        margin-bottom: 8px;
        text-transform: uppercase;
    }

    .stat-desc {
        font-family: 'Inter', sans-serif;
        font-size: 0.75rem;
        color: #555555;
        letter-spacing: 0.5px;
        max-width: 160px;
        line-height: 1.5;
    }

    @media (max-width: 768px) {
        .stats-grid {
            flex-wrap: wrap;
            gap: 40px;
        }
        .divisor { display: none; }
        .stat-item {
            flex: 0 0 calc(50% - 20px);
            padding: 0;
        }
    }

    @media (max-width: 480px) {
        .stat-item { flex: 0 0 100%; }
    }
</style>
