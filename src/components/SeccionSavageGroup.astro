---
// src/components/SeccionSavageGroup.astro
const fotoIconoCloudinary = "https://res.cloudinary.com/dauuk5yar/image/upload/v1773679337/icono_blbjcu.png";
---

<section id="savage-group" class="seccion-equipo">
    <div class="contenedor-equipo">
        
        <div class="cabecera-equipo">
            <h2 class="titulo-manada">SAVAGE GROUP</h2>
            <p class="subtitulo-equipo">LA MANADA DETRÁS DEL INSTINTO</p>
            <div class="linea-dorada"></div>
        </div>

        <div class="grid-equipo">
            
            <div class="tarjeta-miembro">
                <div class="contenedor-foto">
                    <img src={fotoIconoCloudinary} alt="Sebastián Dura" class="foto-miembro" />
                </div>
                <h3 class="nombre-miembro">SEBASTIÁN DURÁN | FOUNDER & PRESIDENT</h3>
                <span class="cargo-miembro"></span>
                <p class="desc-miembro">El estratega global. Su visión comercial impulsa a Savage a romper fronteras, asegurando que nuestra energía salvaje domine nuevos mercados con un posicionamiento premium y disruptivo.</p>
            </div>

            <div class="tarjeta-miembro">
                <div class="contenedor-foto">
                    <img src={fotoIconoCloudinary} alt="Pablo Medina" class="foto-miembro" />
                </div>
                <h3 class="nombre-miembro">PABLO MEDINA | HEAD OF IT</h3>
                <span class="cargo-miembro"></span>
                <p class="desc-miembro">El arquitecto digital. Transforma ideas complejas en experiencias visuales de alto impacto, liderando la identidad tecnológica y la presencia interactiva de la marca con precisión quirúrgica.</p>
            </div>

            <div class="tarjeta-miembro">
                <div class="contenedor-foto">
                    <img src={fotoIconoCloudinary} alt="Martín Araya" class="foto-miembro" />
                </div>
                <h3 class="nombre-miembro">MARTÍN ARAYA | HEAD OF IT</h3>
                <span class="cargo-miembro"></span>
                <p class="desc-miembro">El motor de innovación. Su capacidad analítica garantiza que la infraestructura de Savage opere con la misma potencia, velocidad y exactitud que el contenido de nuestras latas.</p>
            </div>

            <div class="tarjeta-miembro">
                <div class="contenedor-foto">
                    <img src={fotoIconoCloudinary} alt="Leonardo Cerda" class="foto-miembro" />
                </div>
                <h3 class="nombre-miembro">LEONARDO CERDA | HEAD OF OPERATIONS & LOGISTICS</h3>
                <span class="cargo-miembro"></span>
                <p class="desc-miembro">La fuerza operativa. Forjado en la exigencia del terreno, aporta el carácter indomable al grupo, garantizando una cadena de suministro audaz, firme y sin contratiempos.</p>
            </div>

            <div class="tarjeta-miembro">
                <div class="contenedor-foto">
                    <img src={fotoIconoCloudinary} alt="Chaysan Lee" class="foto-miembro" />
                </div>
                <h3 class="nombre-miembro">CHAYSTAN LEE | HEAD OF SALES</h3>
                <span class="cargo-miembro"></span>
                <p class="desc-miembro">El puente con el mundo. Experto en alianzas estratégicas, asegura que la identidad letal de Savage se mantenga intacta en cada cierre comercial y negociación de alto nivel.</p>
            </div>

        </div>
    </div>
</section>

<style>
    .seccion-equipo {
        background-color: #080808; /* Un negro muy profundo para contrastar */
        padding: 100px 20px;
        width: 100%;
        display: flex;
        justify-content: center;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .contenedor-equipo {
        max-width: 1200px;
        width: 100%;
        text-align: center;
    }

    .cabecera-equipo {
        margin-bottom: 70px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .titulo-manada {
        font-family: 'Oswald', sans-serif;
        font-size: 3.5rem;
        color: #ffffff;
        margin: 0 0 10px 0;
        letter-spacing: 2px;
    }

    .subtitulo-equipo {
        font-family: 'Inter', sans-serif;
        font-size: 1.1rem;
        color: #facc15;
        letter-spacing: 4px;
        text-transform: uppercase;
        font-weight: 700;
        margin: 0 0 20px 0;
    }

    .linea-dorada {
        width: 80px;
        height: 3px;
        background-color: #facc15;
    }

    /* GRID PARA LOS 5 MIEMBROS */
    .grid-equipo {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 40px;
    }

    .tarjeta-miembro {
        background-color: #111111;
        border: 1px solid #222;
        border-radius: 16px;
        padding: 40px 30px;
        width: calc(33.333% - 27px); /* 3 columnas arriba */
        min-width: 280px;
        max-width: 350px;
        display: flex;
        flex-direction: column;
        align-items: center;
        transition: transform 0.3s ease, border-color 0.3s ease;
    }

    .tarjeta-miembro:hover {
        transform: translateY(-10px);
        border-color: #facc15;
    }

    .contenedor-foto {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background-color: #222;
        margin-bottom: 25px;
        overflow: hidden;
        border: 3px solid #333;
        transition: border-color 0.3s ease;
    }

    .tarjeta-miembro:hover .contenedor-foto {
        border-color: #facc15;
    }

    .foto-miembro {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .nombre-miembro {
        font-family: 'Oswald', sans-serif;
        font-size: 1.6rem;
        color: #ffffff;
        margin: 0 0 5px 0;
        letter-spacing: 1px;
    }

    .cargo-miembro {
        font-family: 'Inter', sans-serif;
        font-size: 0.8rem;
        color: #facc15;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 600;
        margin-bottom: 20px;
        text-align: center;
    }

    .desc-miembro {
        font-family: 'Inter', sans-serif;
        font-size: 0.95rem;
        color: #a3a3a3;
        line-height: 1.6;
        text-align: center;
        margin: 0;
    }

    /* RESPONSIVE */
    @media (max-width: 1024px) {
        .tarjeta-miembro { width: calc(50% - 20px); } /* 2 columnas en tablets */
    }
    @media (max-width: 650px) {
        .tarjeta-miembro { width: 100%; } /* 1 columna en celulares */
    }
</style>