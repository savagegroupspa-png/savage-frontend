---
// src/components/SeccionSavageGroup.astro
const fotoIconoCloudinary = "https://res.cloudinary.com/dauuk5yar/image/upload/v1773679337/icono_blbjcu.png";
---

<section id="savage-group" class="seccion-equipo">
    <div class="contenedor-equipo">

        <div class="cabecera-equipo reveal-up">
            <h2 class="titulo-manada">SAVAGE GROUP</h2>
            <p class="subtitulo-equipo">LA MANADA DETRÁS DEL INSTINTO</p>
            <div class="linea-dorada"></div>
        </div>

        <div class="grid-equipo">

            <div class="tarjeta-miembro">
                <div class="contenedor-foto">
                    <img src={fotoIconoCloudinary} alt="Sebastián Durán" class="foto-miembro" />
                </div>
                <h3 class="nombre-miembro">SEBASTIÁN DURÁN</h3>
                <span class="cargo-miembro">FOUNDER & PRESIDENT</span>
                <p class="desc-miembro">El estratega global. Su visión comercial impulsa a Savage a romper fronteras, asegurando que nuestra energía salvaje domine nuevos mercados con un posicionamiento premium y disruptivo.</p>
            </div>

            <div class="tarjeta-miembro">
                <div class="contenedor-foto">
                    <img src={fotoIconoCloudinary} alt="Pablo Medina" class="foto-miembro" />
                </div>
                <h3 class="nombre-miembro">PABLO MEDINA</h3>
                <span class="cargo-miembro">HEAD OF IT</span>
                <p class="desc-miembro">El arquitecto digital. Transforma ideas complejas en experiencias visuales de alto impacto, liderando la identidad tecnológica y la presencia interactiva de la marca con precisión quirúrgica.</p>
            </div>

            <div class="tarjeta-miembro">
                <div class="contenedor-foto">
                    <img src={fotoIconoCloudinary} alt="Martín Araya" class="foto-miembro" />
                </div>
                <h3 class="nombre-miembro">MARTÍN ARAYA</h3>
                <span class="cargo-miembro">HEAD OF IT</span>
                <p class="desc-miembro">El motor de innovación. Su capacidad analítica garantiza que la infraestructura de Savage opere con la misma potencia, velocidad y exactitud que el contenido de nuestras latas.</p>
            </div>

            <div class="tarjeta-miembro">
                <div class="contenedor-foto">
                    <img src={fotoIconoCloudinary} alt="Leonardo Cerda" class="foto-miembro" />
                </div>
                <h3 class="nombre-miembro">LEONARDO CERDA</h3>
                <span class="cargo-miembro">HEAD OF OPERATIONS & LOGISTICS</span>
                <p class="desc-miembro">La fuerza operativa. Forjado en la exigencia del terreno, aporta el carácter indomable al grupo, garantizando una cadena de suministro audaz, firme y sin contratiempos.</p>
            </div>

            <div class="tarjeta-miembro">
                <div class="contenedor-foto">
                    <img src={fotoIconoCloudinary} alt="Chaystan Lee" class="foto-miembro" />
                </div>
                <h3 class="nombre-miembro">CHAYSTAN LEE</h3>
                <span class="cargo-miembro">HEAD OF SALES</span>
                <p class="desc-miembro">El puente con el mundo. Experto en alianzas estratégicas, asegura que la identidad letal de Savage se mantenga intacta en cada cierre comercial y negociación de alto nivel.</p>
            </div>

        </div>
    </div>
</section>

<script>
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
            }
        });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal-up, .tarjeta-miembro').forEach(el => observer.observe(el));
</script>

<style>
    .seccion-equipo {
        background-color: #080808;
        padding: 100px 20px;
        width: 100%;
        display: flex;
        justify-content: center;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .contenedor-equipo {
        max-width: 1200px;
        width: 100%;
        text-align: center;
    }

    /* REVEAL */
    .reveal-up {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.8s ease, transform 0.8s ease;
    }

    .reveal-up.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .tarjeta-miembro {
        opacity: 0;
        transform: translateY(40px);
        transition: opacity 0.7s ease, transform 0.7s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    }

    .tarjeta-miembro.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .tarjeta-miembro:nth-child(1) { transition-delay: 0.05s; }
    .tarjeta-miembro:nth-child(2) { transition-delay: 0.15s; }
    .tarjeta-miembro:nth-child(3) { transition-delay: 0.25s; }
    .tarjeta-miembro:nth-child(4) { transition-delay: 0.35s; }
    .tarjeta-miembro:nth-child(5) { transition-delay: 0.45s; }

    .cabecera-equipo {
        margin-bottom: 70px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .titulo-manada {
        font-family: 'Oswald', sans-serif;
        font-size: 3.5rem;
        color: #ffffff;
        margin: 0 0 10px 0;
        letter-spacing: 3px;
    }

    .subtitulo-equipo {
        font-family: 'Inter', sans-serif;
        font-size: 1rem;
        color: #facc15;
        letter-spacing: 5px;
        text-transform: uppercase;
        font-weight: 700;
        margin: 0 0 20px 0;
    }

    .linea-dorada {
        width: 60px;
        height: 2px;
        background: linear-gradient(to right, transparent, #facc15, transparent);
    }

    .grid-equipo {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 30px;
    }

    .tarjeta-miembro {
        background-color: #0e0e0e;
        border: 1px solid #1e1e1e;
        border-radius: 16px;
        padding: 40px 28px;
        width: calc(33.333% - 20px);
        min-width: 260px;
        max-width: 340px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .tarjeta-miembro:hover {
        transform: translateY(-10px) !important;
        border-color: rgba(250, 204, 21, 0.4);
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4), 0 0 30px rgba(250, 204, 21, 0.08);
    }

    .contenedor-foto {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        background-color: #1a1a1a;
        margin-bottom: 22px;
        overflow: hidden;
        border: 2px solid #2a2a2a;
        transition: border-color 0.3s ease;
    }

    .tarjeta-miembro:hover .contenedor-foto {
        border-color: #facc15;
    }

    .foto-miembro {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .nombre-miembro {
        font-family: 'Oswald', sans-serif;
        font-size: 1.3rem;
        color: #ffffff;
        margin: 0 0 6px 0;
        letter-spacing: 1.5px;
    }

    .cargo-miembro {
        font-family: 'Inter', sans-serif;
        font-size: 0.7rem;
        color: #facc15;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        font-weight: 700;
        margin-bottom: 18px;
        text-align: center;
        display: block;
    }

    .desc-miembro {
        font-family: 'Inter', sans-serif;
        font-size: 0.9rem;
        color: #777777;
        line-height: 1.65;
        text-align: center;
        margin: 0;
    }

    @media (max-width: 1024px) {
        .tarjeta-miembro { width: calc(50% - 15px); }
    }

    @media (max-width: 650px) {
        .tarjeta-miembro { width: 100%; max-width: 100%; }
        .titulo-manada { font-size: 2.5rem; }
    }
</style>
