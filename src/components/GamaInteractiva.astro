---
// src/components/GamaInteractiva.astro

const imgPremium = "https://res.cloudinary.com/dauuk5yar/image/upload/v1778291084/maracuya_1_SF_ctm8kv.png";
const imgPineapple = "https://res.cloudinary.com/dauuk5yar/image/upload/v1778291084/pi%C3%B1a_3_SF_u1oelo.png";
const imgMango = "https://res.cloudinary.com/dauuk5yar/image/upload/v1778291084/mango_2_SF_p5dzce.png";
const imgExotic = "https://res.cloudinary.com/dauuk5yar/image/upload/v1778291084/durazno_4_SF_kqavow.png"; 
---

<div id="producto" class="seccion-interactiva">
    
    <div class="origen-header">
        <h1>EL ORIGEN DEL SABOR</h1>
        <p>Nuestras bebidas no nacen en laboratorios, nacen en la tierra. Seleccionamos la mejor fruta desde sus raíces para extraer su esencia más pura. Haz clic en tu lata favorita y descubre la energía que desafía lo convencional.</p>
    </div>

    <div id="escenario" class="escenario-wrapper tema-passion">
        
        <div class="visor-principal">
            
            <div class="info-dinamica">
                <h2 id="titulo-sabor">PASSION FRUIT</h2>
                <h3 id="tagline-sabor">La Intensidad de la Noche.</h3>
                
                <div class="bloque-info">
                    <h4>LA HISTORIA</h4>
                    <p id="historia-sabor">Savage Passion Fruit nació en las noches legendarias, donde la energía no se detiene. Queríamos capturar la vibración de la música y la intensidad de los encuentros en una lata que no se pareciera a nada.</p>
                </div>

                <div class="bloque-info">
                    <h4>LO QUE CONTIENE</h4>
                    <p id="ingredientes-sabor"><strong>Pulpa de Maracuyá Real:</strong> Sentirás la acidez y el dulzor vibrante. <strong>Semillas Reales:</strong> No las quitamos; aportan una textura y un crujido inigualable.</p>
                </div>
            </div>

            <div class="lata-destacada-container">
                <div class="contenedor-imagen-grande">
                    <img id="lata-grande" src={imgPremium} alt="Savage Can" />
                </div>
            </div>

        </div>

        <div class="selector-sabores">
            <button class="latita-btn activo" data-sabor="passion">
                <img src={imgPremium} alt="Passion" class="latita-img" />
            </button>
            <button class="latita-btn" data-sabor="pineapple">
                <img src={imgPineapple} alt="Pineapple" class="latita-img" />
            </button>
            <button class="latita-btn" data-sabor="mango">
                <img src={imgMango} alt="Mango" class="latita-img" />
            </button>
            <button class="latita-btn" data-sabor="exotic">
                <img src={imgExotic} alt="Exotic" class="latita-img" />
            </button>
        </div>

    </div>
</div>

<script>
    const baseDatosSabores = {
        passion: {
            titulo: "PASSION FRUIT",
            tagline: "La Intensidad de la Noche.",
            historia: "Wild Maracuyá nació en las noches legendarias, donde la energía no se detiene. Queríamos capturar la vibración de la música y la intensidad de los encuentros en una lata que no se pareciera a nada.",
            ingredientes: "<strong>Wild Maracuyá:</strong> Acidez brutal con pulpa y <strong>Semillas Crujientes</strong> Aportando una textura y un crujido inigualable.",
            imagen: "https://res.cloudinary.com/dauuk5yar/image/upload/v1778291084/maracuya_1_SF_ctm8kv.png",
            claseColor: "tema-passion"
        },
        pineapple: {
            titulo: "PINEAPPLE",
            tagline: "El Escape Tropical del Sol.",
            historia: "Diseñada para los días largos y los veranos sin fin bajo el sol de la costa. Wild Piña es tu boleto de ida a un paraíso salvaje. Es el frescor que necesitas para recargar energías y liberar tu instinto.",
            ingredientes: "<strong>Wild Piña:</strong> Frescura pura con pulpa y  <strong>Trozos de Fruta Real:</strong> Sí, hay trozos. Cada sorbo es un recordatorio de que Savage es fruta de verdad.",
            imagen: "https://res.cloudinary.com/dauuk5yar/image/upload/v1778291084/pi%C3%B1a_3_SF_u1oelo.png",
            claseColor: "tema-pineapple"
        },
        mango: {
            titulo: "CREAMY MANGO",
            tagline: "La Energía Terciopelo.",
            historia: "Queríamos crear una energía que te acariciara antes de rugir. Wild Mango es la fusión perfecta entre la suavidad del terciopelo y la fuerza de la fruta madura. Un poder sostenido e imparable.",
            ingredientes: "<strong>Wild Mango:</strong> Dulzor intenso con pulpa densa y real. <strong>Fórmula Pura:</strong> Sin vueltas, solo el poder natural de la fruta impulsando tu instinto.",
            imagen: "https://res.cloudinary.com/dauuk5yar/image/upload/v1778291084/mango_2_SF_p5dzce.png",
            claseColor: "tema-mango"
        },
        exotic: {
            titulo: "EXOTIC SOURSOP",
            tagline: "La Bestia de lo Desconocido.",
            historia: "Queríamos un saber que te sedujera antes de desatar tu instinto. Wild Durazno es la colisión perfecta entre la piel suave del sol y el corazón indomable de la fruta. Un poder orgánico, salvaje e imparable.",
            ingredientes: "<strong>Wild Durzano:</strong> El sabor único del durazno con su textura que acaricia el paladar. <strong>Sabor Potente:</strong> pulpa líquida directamente del huerto.",
            imagen: "https://res.cloudinary.com/dauuk5yar/image/upload/v1778291084/durazno_4_SF_kqavow.png",
            claseColor: "tema-exotic"
        }
    };

    const botones = document.querySelectorAll('.latita-btn');
    const escenario = document.getElementById('escenario') as HTMLElement;
    const elTitulo = document.getElementById('titulo-sabor') as HTMLElement;
    const elTagline = document.getElementById('tagline-sabor') as HTMLElement;
    const laHistoria = document.getElementById('historia-sabor') as HTMLElement;
    const losIngredientes = document.getElementById('ingredientes-sabor') as HTMLElement;
    const laLataGrande = document.getElementById('lata-grande') as HTMLImageElement; 
    const infoContainer = document.querySelector('.info-dinamica') as HTMLElement;

    botones.forEach(boton => {
        boton.addEventListener('click', () => {
            botones.forEach(b => b.classList.remove('activo'));
            boton.classList.add('activo');

            const saborSeleccionado = boton.getAttribute('data-sabor') as keyof typeof baseDatosSabores;
            const data = baseDatosSabores[saborSeleccionado];

            if (!data) return; 

            infoContainer.style.opacity = '0';
            laLataGrande.style.transform = 'scale(0.9) translateY(20px)';
            laLataGrande.style.opacity = '0';

            setTimeout(() => {
                elTitulo.innerHTML = data.titulo;
                elTagline.innerHTML = data.tagline;
                laHistoria.innerHTML = data.historia;
                losIngredientes.innerHTML = data.ingredientes;
                laLataGrande.src = data.imagen;
                
                escenario.className = `escenario-wrapper ${data.claseColor}`;

                infoContainer.style.opacity = '1';
                laLataGrande.style.transform = 'scale(1) translateY(0)';
                laLataGrande.style.opacity = '1';
            }, 300); 
        });
    });
</script>

<style>
    :root {
        --c-passion: #4a0054;
        --c-pineapple: #46631f;
        --c-mango: #6a470e;
        --c-exotic: #1a1a1a;
    }

    .seccion-interactiva {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 40px 20px 100px;
        background-color: #050505;
    }

    /* ORIGEN */
    .origen-header { max-width: 800px; text-align: center; margin-bottom: 60px; }
    .origen-header h1 { font-family: 'Oswald', sans-serif; font-size: 3rem; color: #facc15; margin-bottom: 20px; letter-spacing: 2px; }
    .origen-header p { font-family: 'Inter', sans-serif; font-size: 1.1rem; color: #cccccc; line-height: 1.6; }

    /* EL ESCENARIO CENTRAL */
    .escenario-wrapper {
        width: 100%;
        max-width: 1200px;
        border-radius: 40px;
        padding: 60px 70px 40px;
        display: flex;
        flex-direction: column;
        align-items: center;
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        transition: background-color 0.6s ease;
    }

    .tema-passion { background-color: var(--c-passion); }
    .tema-pineapple { background-color: var(--c-pineapple); }
    .tema-mango { background-color: var(--c-mango); }
    .tema-exotic { background-color: var(--c-exotic); }

    .visor-principal {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 40px;
        margin-bottom: 50px;
        min-height: 520px;
    }

    /* Textos Izquierda */
    .info-dinamica {
        flex: 1;
        min-width: 380px;
        max-width: 560px;
        color: white;
        transition: opacity 0.3s ease;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0;
    }

    .info-dinamica h2 {
        font-family: 'Oswald', sans-serif;
        font-size: clamp(3.5rem, 5vw, 6rem);
        margin: 0 0 12px 0;
        line-height: 0.95;
        letter-spacing: -1px;
        text-shadow: 0 5px 15px rgba(0,0,0,0.3);
    }

    .info-dinamica h3 {
        font-family: 'Oswald', sans-serif;
        font-size: 1.6rem;
        color: #facc15;
        margin: 0 0 36px 0;
        letter-spacing: 0.5px;
        font-style: italic;
    }

    .bloque-info { margin-bottom: 24px; }

    .bloque-info h4 {
        font-family: 'Inter', sans-serif;
        font-size: 0.72rem;
        letter-spacing: 3px;
        margin: 0 0 8px 0;
        opacity: 0.5;
        text-transform: uppercase;
    }

    .bloque-info p {
        font-family: 'Inter', sans-serif;
        font-size: 1.05rem;
        line-height: 1.75;
        opacity: 0.88;
        margin: 0;
    }

    /* Imagen Derecha */
    .lata-destacada-container {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .contenedor-imagen-grande {
        display: flex;
        align-items: center;
        justify-content: center;
        filter: drop-shadow(0 40px 80px rgba(0,0,0,0.8));
    }

    .contenedor-imagen-grande img {
        height: 520px;
        width: auto;
        display: block;
        transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.3s ease;
        animation: floatCan 5s ease-in-out infinite;
    }

    @keyframes floatCan {
        0%, 100% { transform: translateY(0px) scale(1); }
        50% { transform: translateY(-14px) scale(1.02); }
    }

    /* PARTE INFERIOR: SELECTOR DE LATITAS */
    .selector-sabores {
        display: flex;
        gap: 30px;
        background: rgba(0,0,0,0.3);
        padding: 20px 40px;
        border-radius: 50px;
        backdrop-filter: blur(10px);
        align-items: flex-end;
    }

    .latita-btn {
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 0;
        transition: transform 0.3s ease, filter 0.3s ease;
        filter: grayscale(80%) opacity(0.6);
        outline: none;
        display: flex;
        align-items: flex-end;
    }

    .latita-btn:hover, .latita-btn.activo {
        transform: scale(1.15) translateY(-10px);
        filter: grayscale(0%) opacity(1);
    }

    .latita-btn.activo {
        filter: grayscale(0%) opacity(1) drop-shadow(0 0 12px rgba(250, 204, 21, 0.6));
    }

    .latita-img {
        width: auto;
        height: 80px;
        object-fit: contain;
        display: block;
    }

    /* RESPONSIVE */
    @media (max-width: 900px) {
        .visor-principal { flex-direction: column-reverse; text-align: center; min-height: unset; gap: 30px; }
        .info-dinamica { min-width: unset; }
        .info-dinamica h2 { font-size: 2.8rem; }
        .contenedor-imagen-grande img { height: 320px; }
        .selector-sabores { gap: 15px; padding: 15px 25px; }
        .latita-img { width: 45px; }
    }
</style>