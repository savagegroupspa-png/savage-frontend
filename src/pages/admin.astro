---
// src/pages/admin.astro — Dashboard Administrativo Savage Group SpA
---
<!doctype html>
<html lang="es">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<title>Savage Admin — Panel de Control</title>
	<meta name="robots" content="noindex, nofollow" />
	<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<!-- ═══════════════════════════════════════════════════════════════ -->
<!-- PANTALLA DE LOGIN                                              -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<div id="login-screen" class="login-screen">
	<div class="login-bg-pattern"></div>
	<div class="login-card">
		<div class="login-brand">
			<div class="login-logo-icon">
				<svg width="40" height="40" viewBox="0 0 40 40" fill="none">
					<rect width="40" height="40" rx="10" fill="#facc15"/>
					<text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" fill="#000" font-family="Oswald" font-weight="700" font-size="16">SG</text>
				</svg>
			</div>
			<h1>SAVAGE GROUP</h1>
			<p>Panel Administrativo</p>
		</div>
		<form id="login-form" class="login-form">
			<div class="input-group">
				<svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
				<input type="email" id="login-email" required placeholder="Correo electrónico" autocomplete="email" />
			</div>
			<div class="input-group">
				<svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
				<input type="password" id="login-password" required placeholder="Contraseña" autocomplete="current-password" />
			</div>
			<button type="submit" id="login-btn" class="login-btn">
				<span class="login-btn-text">INICIAR SESIÓN</span>
				<svg class="login-btn-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
			</button>
			<div id="login-error" class="login-error"></div>
		</form>
		<div class="login-footer">
			<span>Savage Group SpA © 2026</span>
		</div>
	</div>
</div>

<!-- ═══════════════════════════════════════════════════════════════ -->
<!-- LAYOUT DEL DASHBOARD                                           -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<div id="app-layout" class="app-layout hidden">

	<!-- SIDEBAR -->
	<aside class="sidebar" id="sidebar">
		<div class="sidebar-brand">
			<div class="sidebar-logo">
				<svg width="32" height="32" viewBox="0 0 40 40" fill="none">
					<rect width="40" height="40" rx="10" fill="#facc15"/>
					<text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" fill="#000" font-family="Oswald" font-weight="700" font-size="16">SG</text>
				</svg>
			</div>
			<div class="sidebar-brand-text">
				<span class="sidebar-title">SAVAGE</span>
				<span class="sidebar-sub">Admin Panel</span>
			</div>
		</div>

		<nav class="sidebar-nav">
			<div class="sidebar-section-label">PRINCIPAL</div>
			<a href="#" class="sidebar-link active" data-view="overview">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
				<span>Visión General</span>
			</a>
			<a href="#" class="sidebar-link" data-view="transactions">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
				<span>Transacciones</span>
			</a>
			<a href="#" class="sidebar-link" data-view="clients">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
				<span>Clientes</span>
			</a>
			<a href="#" class="sidebar-link" data-view="upload">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
				<span>Registrar Factura</span>
			</a>

			<div class="sidebar-section-label">SISTEMA</div>
			<a href="/" class="sidebar-link">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
				<span>Volver al Sitio</span>
			</a>
		</nav>

		<div class="sidebar-footer">
			<div class="sidebar-user" id="sidebar-user">
				<div class="sidebar-user-avatar">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
				</div>
				<span class="sidebar-user-email" id="user-email">admin</span>
			</div>
			<button id="btn-logout" class="btn-logout-sidebar" title="Cerrar Sesión">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
			</button>
		</div>
	</aside>

	<!-- CONTENIDO PRINCIPAL -->
	<main class="main-content">
		<!-- TOPBAR -->
		<header class="topbar">
			<button class="topbar-toggle" id="sidebar-toggle" aria-label="Alternar menú">
				<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
			</button>
			<div class="topbar-info">
				<h2 id="topbar-title">Visión General</h2>
				<span class="topbar-date" id="topbar-date"></span>
			</div>
		</header>

		<!-- ══ VISTA: OVERVIEW ══ -->
		<div id="view-overview" class="view active">
			<!-- TARJETAS KPI -->
			<div class="kpi-grid">
				<div class="kpi-card">
					<div class="kpi-icon income-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
					</div>
					<div class="kpi-data">
						<span class="kpi-label">INGRESOS / VENTAS</span>
						<span class="kpi-value" id="kpi-ventas">$0</span>
						<span class="kpi-sub">Total acumulado</span>
					</div>
					<div class="kpi-accent income-accent"></div>
				</div>
				<div class="kpi-card">
					<div class="kpi-icon expense-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
					</div>
					<div class="kpi-data">
						<span class="kpi-label">GASTOS OPERATIVOS</span>
						<span class="kpi-value" id="kpi-gastos">$0</span>
						<span class="kpi-sub">Costos de operación</span>
					</div>
					<div class="kpi-accent expense-accent"></div>
				</div>
				<div class="kpi-card">
					<div class="kpi-icon loss-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
					</div>
					<div class="kpi-data">
						<span class="kpi-label">PÉRDIDAS / MERMAS</span>
						<span class="kpi-value" id="kpi-perdidas">$0</span>
						<span class="kpi-sub">Pérdidas identificadas</span>
					</div>
					<div class="kpi-accent loss-accent"></div>
				</div>
				<div class="kpi-card" id="kpi-balance-card">
					<div class="kpi-icon balance-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
					</div>
					<div class="kpi-data">
						<span class="kpi-label">BALANCE NETO</span>
						<span class="kpi-value" id="kpi-balance">$0</span>
						<span class="kpi-sub" id="kpi-balance-sub">Resultado del ejercicio</span>
					</div>
					<div class="kpi-accent balance-accent" id="balance-accent"></div>
				</div>
			</div>

			<!-- GRÁFICO + RESUMEN RÁPIDO -->
			<div class="overview-grid">
				<div class="card chart-panel">
					<div class="card-header">
						<h3>Tendencia Financiera Mensual</h3>
					</div>
					<div class="chart-wrapper">
						<canvas id="financialChart"></canvas>
					</div>
				</div>
				<div class="card recent-panel">
					<div class="card-header">
						<h3>Últimas Transacciones</h3>
					</div>
					<div id="recent-list" class="recent-list">
						<div class="empty-state-small">Sin transacciones aún</div>
					</div>
				</div>
			</div>
		</div>

		<!-- ══ VISTA: TRANSACCIONES ══ -->
		<div id="view-transactions" class="view">
			<div class="card">
				<div class="card-header table-top-header">
					<h3>Historial de Transacciones</h3>
					<div class="table-controls">
						<div class="search-box">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
							<input type="text" id="table-search" placeholder="Buscar folio, cliente..." />
						</div>
						<select id="table-filter-tipo" class="filter-select">
							<option value="all">Todos los tipos</option>
							<option value="venta">Ventas</option>
							<option value="gasto">Gastos</option>
							<option value="perdida">Pérdidas</option>
						</select>
					</div>
				</div>
				<div class="table-responsive">
					<table>
						<thead>
							<tr>
								<th>Fecha</th>
								<th>Folio</th>
								<th>Tipo</th>
								<th>Cliente / Proveedor</th>
								<th>Descripción</th>
								<th class="text-right">Monto (CLP)</th>
								<th>Documento</th>
								<th>Acciones</th>
							</tr>
						</thead>
						<tbody id="transactions-tbody">
							<tr><td colspan="8" class="empty-state">Cargando transacciones...</td></tr>
						</tbody>
					</table>
				</div>
			</div>
		</div>

		<!-- ══ VISTA: SUBIR FACTURA ══ -->
		<div id="view-upload" class="view">
			<div class="upload-layout">
				<div class="card upload-card">
					<div class="card-header">
						<h3>Registrar Nueva Transacción</h3>
					</div>
					<form id="transaction-form">
						<div class="form-grid">
							<div class="form-group">
								<label for="tx-folio">Folio / Nº Documento</label>
								<input type="text" id="tx-folio" placeholder="Ej: 4501" />
							</div>
							<div class="form-group">
								<label for="tx-tipo">Tipo de Transacción</label>
								<select id="tx-tipo" required>
									<option value="venta">Venta / Ingreso</option>
									<option value="gasto">Gasto Operativo</option>
									<option value="perdida">Pérdida / Merma</option>
								</select>
							</div>
							<div class="form-group" id="tx-cliente-group">
								<label for="tx-cliente-select">Cliente (para ventas)</label>
								<select id="tx-cliente-select">
									<option value="">— Seleccionar cliente —</option>
								</select>
							</div>
							<div class="form-group" id="tx-proveedor-group" style="display:none;">
								<label for="tx-proveedor">Proveedor / Origen</label>
								<input type="text" id="tx-proveedor" placeholder="Ej: Envases Plásticos Ltda." />
							</div>
							<div class="form-group">
								<label for="tx-monto">Monto (CLP)</label>
								<input type="number" id="tx-monto" min="0" required placeholder="Ej: 150000" />
							</div>
							<div class="form-group">
								<label for="tx-fecha">Fecha de Emisión</label>
								<input type="date" id="tx-fecha" required />
							</div>
							<div class="form-group">
								<label for="tx-archivo">Adjuntar Factura</label>
								<div class="file-drop-zone" id="file-drop-zone">
									<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
									<span class="file-drop-text" id="file-drop-text">Arrastra o haz clic para subir</span>
									<span class="file-drop-hint">PDF, PNG, JPG (máx. 10MB)</span>
									<input type="file" id="tx-archivo" accept="application/pdf,image/*" />
								</div>
							</div>
						</div>
						<div class="form-group full-width">
							<label for="tx-descripcion">Descripción / Detalle</label>
							<textarea id="tx-descripcion" rows="3" placeholder="Detalle de los productos, mermas o servicios asociados..."></textarea>
						</div>
						<div class="form-actions">
							<button type="submit" id="btn-save-tx" class="btn-primary">
								<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
								<span>Guardar Registro</span>
							</button>
							<button type="reset" class="btn-secondary">Limpiar</button>
						</div>
						<div id="tx-status" class="tx-status"></div>
					</form>
				</div>
			</div>
		</div>

		<!-- ══ VISTA: CLIENTES ══ -->
		<div id="view-clients" class="view">
			<!-- Panel principal de clientes -->
			<div id="clients-main">
				<div class="clients-top">
					<div class="search-box">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
						<input type="text" id="client-search" placeholder="Buscar cliente..." />
					</div>
					<button class="btn-primary" id="btn-show-add-client">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
						<span>Nuevo Cliente</span>
					</button>
				</div>
				<div class="clients-grid" id="clients-grid">
					<div class="empty-state">Cargando clientes...</div>
				</div>
			</div>

			<!-- Formulario agregar cliente -->
			<div id="add-client-panel" class="card" style="display:none;">
				<div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">
					<h3>Registrar Nuevo Cliente</h3>
					<button class="btn-secondary btn-sm" id="btn-cancel-add-client">Cancelar</button>
				</div>
				<form id="client-form" class="form-grid">
					<div class="form-group">
						<label for="cl-nombre">Nombre del Local / Empresa</label>
						<input type="text" id="cl-nombre" required placeholder="Ej: Botillería La Esquina" />
					</div>
					<div class="form-group">
						<label for="cl-rut">RUT</label>
						<input type="text" id="cl-rut" placeholder="Ej: 76.543.210-1" />
					</div>
					<div class="form-group">
						<label for="cl-tipo">Tipo de Negocio</label>
						<select id="cl-tipo">
							<option value="local">Local / Botillería</option>
							<option value="distribuidor">Distribuidor</option>
							<option value="restaurant">Restaurant / Bar</option>
							<option value="cadena">Cadena / Supermercado</option>
							<option value="otro">Otro</option>
						</select>
					</div>
					<div class="form-group">
						<label for="cl-telefono">Teléfono</label>
						<input type="text" id="cl-telefono" placeholder="+56 9 XXXX XXXX" />
					</div>
					<div class="form-group">
						<label for="cl-email">Email</label>
						<input type="email" id="cl-email" placeholder="contacto@ejemplo.cl" />
					</div>
					<div class="form-group">
						<label for="cl-ciudad">Ciudad</label>
						<input type="text" id="cl-ciudad" placeholder="Ej: Viña del Mar" />
					</div>
					<div class="form-group">
						<label for="cl-direccion">Dirección</label>
						<input type="text" id="cl-direccion" placeholder="Ej: Av. Libertad 1520" />
					</div>
					<div class="form-group">
						<label for="cl-notas">Notas</label>
						<input type="text" id="cl-notas" placeholder="Observaciones..." />
					</div>
					<div class="form-actions" style="grid-column:1/-1;">
						<button type="submit" class="btn-primary"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg><span>Guardar Cliente</span></button>
					</div>
				</form>
				<div id="cl-status" class="tx-status"></div>
			</div>

			<!-- Detalle de cliente -->
			<div id="client-detail" class="card" style="display:none;">
				<div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">
					<h3 id="detail-client-name">—</h3>
					<button class="btn-secondary btn-sm" id="btn-back-clients">← Volver</button>
				</div>
				<div class="client-detail-grid">
					<div class="client-info-panel">
						<div class="info-row"><span class="info-label">Tipo</span><span id="detail-tipo" class="info-value">—</span></div>
						<div class="info-row"><span class="info-label">RUT</span><span id="detail-rut" class="info-value">—</span></div>
						<div class="info-row"><span class="info-label">Teléfono</span><span id="detail-telefono" class="info-value">—</span></div>
						<div class="info-row"><span class="info-label">Email</span><span id="detail-email" class="info-value">—</span></div>
						<div class="info-row"><span class="info-label">Dirección</span><span id="detail-direccion" class="info-value">—</span></div>
						<div class="info-row"><span class="info-label">Ciudad</span><span id="detail-ciudad" class="info-value">—</span></div>
						<div class="info-row"><span class="info-label">Notas</span><span id="detail-notas" class="info-value">—</span></div>
					</div>
					<div class="client-stats-panel">
						<div class="client-stat"><span class="client-stat-label">Total Comprado</span><span class="client-stat-value" id="detail-total">$0</span></div>
						<div class="client-stat"><span class="client-stat-label">Nº de Pedidos</span><span class="client-stat-value" id="detail-pedidos">0</span></div>
						<div class="client-stat"><span class="client-stat-label">Última Compra</span><span class="client-stat-value" id="detail-ultima">—</span></div>
					</div>
				</div>
				<h4 style="font-family:Oswald,sans-serif;font-size:1rem;color:#a1a1aa;margin:28px 0 12px;letter-spacing:0.5px;">Historial de Compras</h4>
				<div class="table-responsive">
					<table>
						<thead><tr><th>Fecha</th><th>Folio</th><th>Descripción</th><th class="text-right">Monto</th><th>Documento</th></tr></thead>
						<tbody id="detail-history"><tr><td colspan="5" class="empty-state">Sin compras</td></tr></tbody>
					</table>
				</div>
			</div>
		</div>

	</main>
</div>

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js" is:inline></script>

<script>
	import { createClient } from '@supabase/supabase-js';

	const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || '';
	const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';
	let supabase: any;
	if (supabaseUrl && supabaseAnonKey) {
		supabase = createClient(supabaseUrl, supabaseAnonKey);
	}

	// ── DOM Elements ──
	const loginScreen = document.getElementById('login-screen') as HTMLElement;
	const appLayout = document.getElementById('app-layout') as HTMLElement;
	const loginForm = document.getElementById('login-form') as HTMLFormElement;
	const loginError = document.getElementById('login-error') as HTMLElement;
	const loginBtn = document.getElementById('login-btn') as HTMLButtonElement;
	const btnLogout = document.getElementById('btn-logout') as HTMLElement;

	const txForm = document.getElementById('transaction-form') as HTMLFormElement;
	const txStatus = document.getElementById('tx-status') as HTMLElement;
	const btnSaveTx = document.getElementById('btn-save-tx') as HTMLButtonElement;

	const kpiVentas = document.getElementById('kpi-ventas') as HTMLElement;
	const kpiGastos = document.getElementById('kpi-gastos') as HTMLElement;
	const kpiPerdidas = document.getElementById('kpi-perdidas') as HTMLElement;
	const kpiBalance = document.getElementById('kpi-balance') as HTMLElement;
	const kpiBalanceCard = document.getElementById('kpi-balance-card') as HTMLElement;
	const kpiBalanceSub = document.getElementById('kpi-balance-sub') as HTMLElement;
	const balanceAccent = document.getElementById('balance-accent') as HTMLElement;

	const tbody = document.getElementById('transactions-tbody') as HTMLElement;
	const searchInput = document.getElementById('table-search') as HTMLInputElement;
	const filterTipo = document.getElementById('table-filter-tipo') as HTMLSelectElement;
	const recentList = document.getElementById('recent-list') as HTMLElement;
	const userEmail = document.getElementById('user-email') as HTMLElement;
	const topbarTitle = document.getElementById('topbar-title') as HTMLElement;
	const topbarDate = document.getElementById('topbar-date') as HTMLElement;

	// Sidebar
	const sidebar = document.getElementById('sidebar') as HTMLElement;
	const sidebarToggle = document.getElementById('sidebar-toggle') as HTMLElement;
	const sidebarLinks = document.querySelectorAll('.sidebar-link[data-view]');

	let chartInstance: any = null;
	let transacciones: any[] = [];
	let clientes: any[] = [];

	// ── Set date in topbar ──
	const now = new Date();
	topbarDate.textContent = now.toLocaleDateString('es-CL', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });

	// ── Sidebar toggle (mobile) ──
	sidebarToggle.addEventListener('click', () => {
		sidebar.classList.toggle('open');
	});

	// ── View switching ──
	const viewTitles: Record<string, string> = {
		overview: 'Visión General',
		transactions: 'Transacciones',
		clients: 'Clientes',
		upload: 'Registrar Factura'
	};

	sidebarLinks.forEach(link => {
		link.addEventListener('click', (e) => {
			e.preventDefault();
			const target = (link as HTMLElement).getAttribute('data-view')!;
			switchView(target);
			sidebar.classList.remove('open');
		});
	});

	function switchView(viewName: string) {
		document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
		document.getElementById(`view-${viewName}`)?.classList.add('active');
		sidebarLinks.forEach(l => l.classList.remove('active'));
		document.querySelector(`[data-view="${viewName}"]`)?.classList.add('active');
		topbarTitle.textContent = viewTitles[viewName] || viewName;
	}

	// ── File drop zone ──
	const fileDropZone = document.getElementById('file-drop-zone') as HTMLElement;
	const fileInput = document.getElementById('tx-archivo') as HTMLInputElement;
	const fileDropText = document.getElementById('file-drop-text') as HTMLElement;

	fileDropZone.addEventListener('click', () => fileInput.click());
	fileDropZone.addEventListener('dragover', (e) => { e.preventDefault(); fileDropZone.classList.add('dragover'); });
	fileDropZone.addEventListener('dragleave', () => fileDropZone.classList.remove('dragover'));
	fileDropZone.addEventListener('drop', (e) => {
		e.preventDefault();
		fileDropZone.classList.remove('dragover');
		if (e.dataTransfer?.files.length) {
			fileInput.files = e.dataTransfer.files;
			fileDropText.textContent = e.dataTransfer.files[0].name;
			fileDropZone.classList.add('has-file');
		}
	});
	fileInput.addEventListener('change', () => {
		if (fileInput.files?.length) {
			fileDropText.textContent = fileInput.files[0].name;
			fileDropZone.classList.add('has-file');
		}
	});

	// ── Auth ──
	async function checkSession() {
		if (!supabase) {
			loginError.textContent = 'Error: Credenciales de Supabase no configuradas.';
			return;
		}
		const { data: { session } } = await supabase.auth.getSession();
		if (session) {
			showDashboard(session.user?.email || 'admin');
		} else {
			showLogin();
		}
	}

	function showLogin() {
		loginScreen.classList.remove('hidden');
		appLayout.classList.add('hidden');
	}

	function showDashboard(email?: string) {
		loginScreen.classList.add('hidden');
		appLayout.classList.remove('hidden');
		if (email) userEmail.textContent = email;
		loadData();
		loadClients();
	}

	loginForm.addEventListener('submit', async (e) => {
		e.preventDefault();
		loginError.textContent = '';
		loginBtn.classList.add('loading');

		const email = (document.getElementById('login-email') as HTMLInputElement).value.trim();
		const password = (document.getElementById('login-password') as HTMLInputElement).value;

		try {
			const { data, error } = await supabase.auth.signInWithPassword({ email, password });
			if (error) throw error;
			showDashboard(data.user?.email);
		} catch (error: any) {
			loginError.textContent = error.message || 'Credenciales incorrectas.';
		} finally {
			loginBtn.classList.remove('loading');
		}
	});

	btnLogout.addEventListener('click', async () => {
		await supabase.auth.signOut();
		showLogin();
	});

	// ── Data ──
	async function loadData() {
		try {
			const { data, error } = await supabase
				.from('transacciones')
				.select('*')
				.order('fecha', { ascending: false });
			if (error) throw error;
			transacciones = data || [];
			renderDashboard();
		} catch (error: any) {
			console.error('Error:', error);
			tbody.innerHTML = `<tr><td colspan="8" class="empty-state error-text">Error: ${error.message}</td></tr>`;
		}
	}

	function formatCLP(val: number) {
		return new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 }).format(val);
	}

	function renderDashboard() {
		let totalVentas = 0, totalGastos = 0, totalPerdidas = 0;
		transacciones.forEach(tx => {
			const m = Number(tx.monto) || 0;
			if (tx.tipo === 'venta') totalVentas += m;
			else if (tx.tipo === 'gasto') totalGastos += m;
			else if (tx.tipo === 'perdida') totalPerdidas += m;
		});
		const balance = totalVentas - totalGastos - totalPerdidas;

		animateValue(kpiVentas, totalVentas);
		animateValue(kpiGastos, totalGastos);
		animateValue(kpiPerdidas, totalPerdidas);
		animateValue(kpiBalance, balance);

		// Balance color
		balanceAccent.className = 'kpi-accent balance-accent';
		if (balance > 0) {
			balanceAccent.classList.add('positive');
			kpiBalanceSub.textContent = 'Resultado positivo';
		} else if (balance < 0) {
			balanceAccent.classList.add('negative');
			kpiBalanceSub.textContent = 'Resultado negativo';
		} else {
			kpiBalanceSub.textContent = 'Sin movimientos';
		}

		renderTable();
		renderChart();
		renderRecentList();
		renderClientCards();
	}

	function animateValue(el: HTMLElement, target: number) {
		const duration = 800;
		const start = performance.now();
		const update = (now: number) => {
			const elapsed = now - start;
			const progress = Math.min(elapsed / duration, 1);
			const eased = 1 - Math.pow(1 - progress, 3); // ease-out cubic
			el.textContent = formatCLP(Math.round(target * eased));
			if (progress < 1) requestAnimationFrame(update);
		};
		requestAnimationFrame(update);
	}

	// ── Recent list ──
	function renderRecentList() {
		const recent = transacciones.slice(0, 6);
		if (recent.length === 0) {
			recentList.innerHTML = '<div class="empty-state-small">Sin transacciones aún</div>';
			return;
		}
		recentList.innerHTML = recent.map(tx => {
			const badgeClass = tx.tipo === 'venta' ? 'badge-venta' : tx.tipo === 'gasto' ? 'badge-gasto' : 'badge-perdida';
			const sign = tx.tipo === 'venta' ? '+' : '-';
			const signClass = tx.tipo === 'venta' ? 'amount-positive' : 'amount-negative';
			return `
				<div class="recent-item">
					<div class="recent-item-left">
						<span class="badge-dot ${badgeClass}"></span>
						<div>
							<span class="recent-name">${tx.cliente_proveedor}</span>
							<span class="recent-date">${tx.fecha}</span>
						</div>
					</div>
					<span class="recent-amount ${signClass}">${sign}${formatCLP(tx.monto)}</span>
				</div>
			`;
		}).join('');
	}

	// ── Table ──
	function renderTable() {
		const search = searchInput.value.toLowerCase();
		const type = filterTipo.value;
		const filtered = transacciones.filter(tx => {
			const matchesSearch =
				(tx.folio && tx.folio.toLowerCase().includes(search)) ||
				(tx.cliente_proveedor && tx.cliente_proveedor.toLowerCase().includes(search)) ||
				(tx.descripcion && tx.descripcion.toLowerCase().includes(search));
			const matchesType = type === 'all' || tx.tipo === type;
			return matchesSearch && matchesType;
		});

		if (filtered.length === 0) {
			tbody.innerHTML = `<tr><td colspan="8" class="empty-state">No se encontraron transacciones.</td></tr>`;
			return;
		}

		tbody.innerHTML = filtered.map(tx => {
			const badgeClass = tx.tipo === 'venta' ? 'badge-venta' : tx.tipo === 'gasto' ? 'badge-gasto' : 'badge-perdida';
			const fileLink = tx.archivo_url
				? `<a href="${tx.archivo_url}" target="_blank" class="link-doc"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg> Ver</a>`
				: `<span class="text-muted">—</span>`;
			return `
				<tr>
					<td>${tx.fecha}</td>
					<td><strong>${tx.folio || '—'}</strong></td>
					<td><span class="badge ${badgeClass}">${tx.tipo.toUpperCase()}</span></td>
					<td>${tx.cliente_proveedor}</td>
					<td class="text-desc" title="${tx.descripcion || ''}">${tx.descripcion || '—'}</td>
					<td class="text-right"><strong>${formatCLP(tx.monto)}</strong></td>
					<td>${fileLink}</td>
					<td><button class="btn-delete" data-id="${tx.id}" title="Eliminar">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
					</button></td>
				</tr>`;
		}).join('');

		document.querySelectorAll('.btn-delete').forEach(btn => {
			btn.addEventListener('click', async (e: any) => {
				const id = e.currentTarget.getAttribute('data-id');
				if (confirm('¿Eliminar este registro permanentemente?')) {
					try {
						const { error } = await supabase.from('transacciones').delete().eq('id', id);
						if (error) throw error;
						loadData();
					} catch (err: any) {
						alert('Error: ' + err.message);
					}
				}
			});
		});
	}

	searchInput.addEventListener('input', renderTable);
	filterTipo.addEventListener('change', renderTable);

	// ── Chart ──
	function renderChart() {
		const canvas = document.getElementById('financialChart') as HTMLCanvasElement;
		if (!canvas) return;

		const monthly: Record<string, { ventas: number, gastos: number, perdidas: number }> = {};
		const sorted = [...transacciones].sort((a, b) => new Date(a.fecha).getTime() - new Date(b.fecha).getTime());

		sorted.forEach(tx => {
			if (!tx.fecha) return;
			const mes = tx.fecha.substring(0, 7);
			if (!monthly[mes]) monthly[mes] = { ventas: 0, gastos: 0, perdidas: 0 };
			const val = Number(tx.monto) || 0;
			if (tx.tipo === 'venta') monthly[mes].ventas += val;
			else if (tx.tipo === 'gasto') monthly[mes].gastos += val;
			else if (tx.tipo === 'perdida') monthly[mes].perdidas += val;
		});

		const labels = Object.keys(monthly);
		const ventas = labels.map(l => monthly[l].ventas);
		const egresos = labels.map(l => monthly[l].gastos + monthly[l].perdidas);

		if (chartInstance) chartInstance.destroy();

		// @ts-ignore
		if (typeof Chart !== 'undefined') {
			// @ts-ignore
			chartInstance = new Chart(canvas, {
				type: 'bar',
				data: {
					labels: labels.map(l => {
						const [y, m] = l.split('-');
						return new Date(Number(y), Number(m) - 1).toLocaleDateString('es-CL', { month: 'short', year: '2-digit' }).toUpperCase();
					}),
					datasets: [
						{
							label: 'Ingresos',
							data: ventas,
							backgroundColor: 'rgba(250, 204, 21, 0.8)',
							borderColor: '#facc15',
							borderWidth: 1,
							borderRadius: 4
						},
						{
							label: 'Egresos',
							data: egresos,
							backgroundColor: 'rgba(239, 68, 68, 0.6)',
							borderColor: '#ef4444',
							borderWidth: 1,
							borderRadius: 4
						}
					]
				},
				options: {
					responsive: true,
					maintainAspectRatio: false,
					plugins: {
						legend: {
							position: 'top',
							align: 'end',
							labels: { color: '#888', font: { family: 'Inter', size: 12 }, boxWidth: 12, boxHeight: 12 }
						}
					},
					scales: {
						y: {
							grid: { color: 'rgba(255,255,255,0.04)' },
							ticks: { color: '#666', font: { family: 'Inter', size: 11 } },
							border: { color: 'rgba(255,255,255,0.06)' }
						},
						x: {
							grid: { display: false },
							ticks: { color: '#666', font: { family: 'Inter', size: 11 } },
							border: { color: 'rgba(255,255,255,0.06)' }
						}
					}
				}
			});
		}
	}

	// ── Transaction form (updated for client select) ──
	const txTipo = document.getElementById('tx-tipo') as HTMLSelectElement;
	const txClienteGroup = document.getElementById('tx-cliente-group') as HTMLElement;
	const txProveedorGroup = document.getElementById('tx-proveedor-group') as HTMLElement;
	const txClienteSelect = document.getElementById('tx-cliente-select') as HTMLSelectElement;
	const txProveedor = document.getElementById('tx-proveedor') as HTMLInputElement;

	// Toggle client/proveedor fields based on transaction type
	txTipo.addEventListener('change', () => {
		if (txTipo.value === 'venta') {
			txClienteGroup.style.display = '';
			txProveedorGroup.style.display = 'none';
		} else {
			txClienteGroup.style.display = 'none';
			txProveedorGroup.style.display = '';
		}
	});

	txForm.addEventListener('submit', async (e) => {
		e.preventDefault();
		txStatus.className = 'tx-status';
		txStatus.textContent = 'Guardando registro...';
		btnSaveTx.disabled = true;

		const folio = (document.getElementById('tx-folio') as HTMLInputElement).value.trim();
		const tipo = txTipo.value;
		const monto = Number((document.getElementById('tx-monto') as HTMLInputElement).value);
		const fecha = (document.getElementById('tx-fecha') as HTMLInputElement).value;
		const descripcion = (document.getElementById('tx-descripcion') as HTMLTextAreaElement).value.trim();

		// Determine client/proveedor
		let clienteId: string | null = null;
		let clienteProveedor = '';
		if (tipo === 'venta') {
			clienteId = txClienteSelect.value || null;
			const selectedOpt = txClienteSelect.options[txClienteSelect.selectedIndex];
			clienteProveedor = selectedOpt?.text || 'Cliente';
			if (!clienteId) {
				txStatus.className = 'tx-status error';
				txStatus.textContent = '❌ Debes seleccionar un cliente para las ventas.';
				btnSaveTx.disabled = false;
				return;
			}
		} else {
			clienteProveedor = txProveedor.value.trim();
			if (!clienteProveedor) {
				txStatus.className = 'tx-status error';
				txStatus.textContent = '❌ Debes ingresar el proveedor u origen.';
				btnSaveTx.disabled = false;
				return;
			}
		}

		try {
			let archivoUrl = '';
			if (fileInput.files && fileInput.files.length > 0) {
				const file = fileInput.files[0];
				const ext = file.name.split('.').pop();
				const fileName = `${folio || Date.now()}_${Math.random().toString(36).substring(7)}.${ext}`;
				const filePath = `facturas/${fileName}`;

				txStatus.textContent = 'Subiendo archivo...';
				const { error: uploadError } = await supabase.storage.from('facturas').upload(filePath, file);
				if (uploadError) throw uploadError;

				const { data: { publicUrl } } = supabase.storage.from('facturas').getPublicUrl(filePath);
				archivoUrl = publicUrl;
			}

			txStatus.textContent = 'Guardando en base de datos...';
			const { error } = await supabase.from('transacciones').insert([{
				folio: folio || null, tipo, cliente_proveedor: clienteProveedor,
				cliente_id: clienteId, monto, fecha, descripcion, archivo_url: archivoUrl || null
			}]);
			if (error) throw error;

			txStatus.className = 'tx-status success';
			txStatus.textContent = '✓ Transacción registrada con éxito.';
			txForm.reset();
			fileDropText.textContent = 'Arrastra o haz clic para subir';
			fileDropZone.classList.remove('has-file');
			txClienteGroup.style.display = '';
			txProveedorGroup.style.display = 'none';
			loadData();
			setTimeout(() => { switchView('overview'); }, 1500);
		} catch (error: any) {
			txStatus.className = 'tx-status error';
			txStatus.textContent = `❌ Error: ${error.message}`;
		} finally {
			btnSaveTx.disabled = false;
		}
	});

	// ═══════════════════════════════════════════════
	// CLIENTES MODULE
	// ═══════════════════════════════════════════════
	const clientsGrid = document.getElementById('clients-grid') as HTMLElement;
	const clientsMain = document.getElementById('clients-main') as HTMLElement;
	const addClientPanel = document.getElementById('add-client-panel') as HTMLElement;
	const clientDetail = document.getElementById('client-detail') as HTMLElement;
	const clientForm = document.getElementById('client-form') as HTMLFormElement;
	const clStatus = document.getElementById('cl-status') as HTMLElement;
	const clientSearch = document.getElementById('client-search') as HTMLInputElement;

	// Show/hide add client form
	document.getElementById('btn-show-add-client')?.addEventListener('click', () => {
		clientsMain.style.display = 'none';
		clientDetail.style.display = 'none';
		addClientPanel.style.display = '';
	});
	document.getElementById('btn-cancel-add-client')?.addEventListener('click', () => {
		addClientPanel.style.display = 'none';
		clientsMain.style.display = '';
	});
	document.getElementById('btn-back-clients')?.addEventListener('click', () => {
		clientDetail.style.display = 'none';
		clientsMain.style.display = '';
	});

	// Load clients
	async function loadClients() {
		try {
			const { data, error } = await supabase.from('clientes').select('*').order('nombre');
			if (error) throw error;
			clientes = data || [];
			renderClientCards();
			populateClientSelect();
		} catch (err: any) {
			clientsGrid.innerHTML = `<div class="empty-state error-text">Error: ${err.message}</div>`;
		}
	}

	// Populate client dropdown in transaction form
	function populateClientSelect() {
		const opts = clientes.map(c => `<option value="${c.id}">${c.nombre || 'Sin Nombre'}${c.ciudad ? ' — ' + c.ciudad : ''}</option>`).join('');
		txClienteSelect.innerHTML = `<option value="">— Seleccionar cliente —</option>` + opts;
	}

	// Render client cards
	function renderClientCards() {
		const search = clientSearch.value.toLowerCase();
		const filtered = clientes.filter(c => {
			const nombre = c.nombre ? String(c.nombre).toLowerCase() : '';
			const ciudad = c.ciudad ? String(c.ciudad).toLowerCase() : '';
			const rut = c.rut ? String(c.rut).toLowerCase() : '';
			return nombre.includes(search) || ciudad.includes(search) || rut.includes(search);
		});

		if (filtered.length === 0) {
			clientsGrid.innerHTML = `<div class="empty-state">No se encontraron clientes.</div>`;
			return;
		}

		clientsGrid.innerHTML = filtered.map(c => {
			// Calculate total purchased
			const clientTxs = transacciones.filter(tx => tx.cliente_id === c.id);
			const totalComprado = clientTxs.reduce((sum: number, tx: any) => sum + (Number(tx.monto) || 0), 0);
			const numPedidos = clientTxs.length;
			const tipoLabels: Record<string, string> = { local: 'Local', distribuidor: 'Distribuidor', restaurant: 'Restaurant', cadena: 'Cadena', otro: 'Otro' };
			const tipoLabel = tipoLabels[c.tipo] || c.tipo || '—';

			return `
				<div class="client-card" data-client-id="${c.id}">
					<div class="client-card-top">
						<div class="client-card-avatar">
							<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
						</div>
						<div class="client-card-info">
							<span class="client-card-name">${c.nombre || 'Sin Nombre'}</span>
							<span class="client-card-meta">${tipoLabel}${c.ciudad ? ' · ' + c.ciudad : ''}</span>
						</div>
					</div>
					<div class="client-card-stats">
						<div class="client-card-stat">
							<span class="client-card-stat-label">Total Comprado</span>
							<span class="client-card-stat-value">${formatCLP(totalComprado)}</span>
						</div>
						<div class="client-card-stat">
							<span class="client-card-stat-label">Pedidos</span>
							<span class="client-card-stat-value">${numPedidos}</span>
						</div>
					</div>
				</div>
			`;
		}).join('');

		// Attach click handlers
		document.querySelectorAll('.client-card').forEach(card => {
			card.addEventListener('click', () => {
				const id = (card as HTMLElement).getAttribute('data-client-id');
				showClientDetail(id!);
			});
		});
	}

	clientSearch.addEventListener('input', renderClientCards);

	// Show client detail
	function showClientDetail(clientId: string) {
		const c = clientes.find(cl => cl.id === clientId);
		if (!c) return;

		clientsMain.style.display = 'none';
		addClientPanel.style.display = 'none';
		clientDetail.style.display = '';

		(document.getElementById('detail-client-name') as HTMLElement).textContent = c.nombre;
		(document.getElementById('detail-tipo') as HTMLElement).textContent = c.tipo ? c.tipo.charAt(0).toUpperCase() + c.tipo.slice(1) : '—';
		(document.getElementById('detail-rut') as HTMLElement).textContent = c.rut || '—';
		(document.getElementById('detail-telefono') as HTMLElement).textContent = c.telefono || '—';
		(document.getElementById('detail-email') as HTMLElement).textContent = c.email || '—';
		(document.getElementById('detail-direccion') as HTMLElement).textContent = c.direccion || '—';
		(document.getElementById('detail-ciudad') as HTMLElement).textContent = c.ciudad || '—';
		(document.getElementById('detail-notas') as HTMLElement).textContent = c.notas || '—';

		// Stats
		const clientTxs = transacciones.filter(tx => tx.cliente_id === clientId).sort((a: any, b: any) => new Date(b.fecha).getTime() - new Date(a.fecha).getTime());
		const total = clientTxs.reduce((s: number, tx: any) => s + (Number(tx.monto) || 0), 0);
		(document.getElementById('detail-total') as HTMLElement).textContent = formatCLP(total);
		(document.getElementById('detail-pedidos') as HTMLElement).textContent = String(clientTxs.length);
		(document.getElementById('detail-ultima') as HTMLElement).textContent = clientTxs.length > 0 ? clientTxs[0].fecha : '—';

		// History table
		const historyTbody = document.getElementById('detail-history') as HTMLElement;
		if (clientTxs.length === 0) {
			historyTbody.innerHTML = '<tr><td colspan="5" class="empty-state">Sin compras registradas</td></tr>';
		} else {
			historyTbody.innerHTML = clientTxs.map((tx: any) => {
				const fileLink = tx.archivo_url
					? `<a href="${tx.archivo_url}" target="_blank" class="link-doc"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg> Ver</a>`
					: '<span class="text-muted">—</span>';
				return `<tr><td>${tx.fecha}</td><td><strong>${tx.folio || '—'}</strong></td><td class="text-desc">${tx.descripcion || '—'}</td><td class="text-right"><strong>${formatCLP(tx.monto)}</strong></td><td>${fileLink}</td></tr>`;
			}).join('');
		}
	}

	// Add client form
	clientForm.addEventListener('submit', async (e) => {
		e.preventDefault();
		clStatus.className = 'tx-status';
		clStatus.textContent = 'Guardando cliente...';

		try {
			const { error } = await supabase.from('clientes').insert([{
				nombre: (document.getElementById('cl-nombre') as HTMLInputElement).value.trim(),
				rut: (document.getElementById('cl-rut') as HTMLInputElement).value.trim() || null,
				tipo: (document.getElementById('cl-tipo') as HTMLSelectElement).value,
				telefono: (document.getElementById('cl-telefono') as HTMLInputElement).value.trim() || null,
				email: (document.getElementById('cl-email') as HTMLInputElement).value.trim() || null,
				ciudad: (document.getElementById('cl-ciudad') as HTMLInputElement).value.trim() || null,
				direccion: (document.getElementById('cl-direccion') as HTMLInputElement).value.trim() || null,
				notas: (document.getElementById('cl-notas') as HTMLInputElement).value.trim() || null
			}]);
			if (error) throw error;

			clStatus.className = 'tx-status success';
			clStatus.textContent = '✓ Cliente registrado con éxito.';
			clientForm.reset();
			await loadClients();
			setTimeout(() => {
				addClientPanel.style.display = 'none';
				clientsMain.style.display = '';
				clStatus.textContent = '';
			}, 1200);
		} catch (err: any) {
			clStatus.className = 'tx-status error';
			clStatus.textContent = `❌ Error: ${err.message}`;
		}
	});

	checkSession();
</script>

