		background: rgba(250, 204, 21, 0.05);
	}
	.file-drop-zone:hover svg,
	.file-drop-zone.dragover svg {
		color: #facc15;
		transform: translateY(-2px);
	}
	.file-drop-zone.has-file { 
		border-color: #facc15; 
		border-style: solid; 
		background: rgba(250, 204, 21, 0.08);
	}
	.file-drop-zone.has-file svg { color: #facc15; transform: none; }
	.file-drop-text { font-size: 0.9rem; color: #a1a1aa; font-weight: 500; }
	.file-drop-zone.has-file .file-drop-text { color: #facc15; }
	.file-drop-hint { font-size: 0.75rem; color: #52525b; }
	.file-drop-zone input[type="file"] { display: none; }

	.form-actions {
		display: flex; gap: 12px;
		margin-top: 24px;
	}
	.btn-primary {
		display: inline-flex; align-items: center; gap: 8px;
		padding: 12px 28px;
		background: #facc15; color: #000;
		border: none; border-radius: 8px;
		font-family: 'Inter', sans-serif;
		font-weight: 600; font-size: 0.85rem;
		cursor: pointer;
		transition: background 0.25s, transform 0.15s;
	}
	.btn-primary:hover:not(:disabled) { background: #eab308; transform: translateY(-1px); }
	.btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }

	.btn-secondary {
		padding: 12px 24px;
		background: transparent; color: #71717a;
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 8px;
		font-family: 'Inter', sans-serif;
		font-size: 0.85rem; cursor: pointer;
		transition: color 0.2s, border-color 0.2s;
	}
	.btn-secondary:hover { color: #d4d4d8; border-color: rgba(255, 255, 255, 0.2); }

	.tx-status {
		margin-top: 16px; font-size: 0.85rem;
		text-align: center; min-height: 24px;
	}
	.tx-status.error { color: #ef4444; }
	.tx-status.success { color: #22c55e; }

	/* ═══════════════════════════════════════════════ */
	/* RESPONSIVE                                     */
	/* ═══════════════════════════════════════════════ */
	@media (max-width: 1100px) {
		.kpi-grid { grid-template-columns: repeat(2, 1fr); }
		.overview-grid { grid-template-columns: 1fr; }
	}

	@media (max-width: 768px) {
		.sidebar {
			transform: translateX(-100%);
			box-shadow: 4px 0 24px rgba(0, 0, 0, 0.5);
		}
		.sidebar.open { transform: translateX(0); }
		.main-content { margin-left: 0; }
		.topbar-toggle { display: block; }
		.view { padding: 20px 16px; }
		.kpi-grid { grid-template-columns: 1fr; }
		.form-grid { grid-template-columns: 1fr; }
		.table-controls { flex-direction: column; width: 100%; }
		.search-box input { width: 100%; }
		.login-card { margin: 16px; padding: 36px 24px; }
	}
</style>

